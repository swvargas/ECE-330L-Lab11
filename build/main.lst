 148:Core/Src/main.c ****   /*** Configure GPIOs ***/
 149:Core/Src/main.c ****   GPIOD->MODER = 0x55555555; // set all Port D pins to outputs
 150:Core/Src/main.c ****   GPIOA->MODER |= 0x000000FF; // Port A mode register - make A0 to A3 analog pins
 151:Core/Src/main.c ****   GPIOE->MODER |= 0x55555555; // Port E mode register - make E0 to E15 outputs
 152:Core/Src/main.c ****   GPIOC->MODER |= 0x0; // Port C mode register - all inputs
 153:Core/Src/main.c ****   GPIOE->ODR = 0xFFFF; // Set all Port E pins high
 154:Core/Src/main.c **** 
 155:Core/Src/main.c ****   /*** Configure ADC1 ***/
 156:Core/Src/main.c ****   RCC->APB2ENR |= 1<<8;  // Turn on ADC1 clock by forcing bit 8 to 1 while keeping other bits uncha
 157:Core/Src/main.c ****   ADC1->SMPR2 |= 1; // 15 clock cycles per sample
 158:Core/Src/main.c ****   ADC1->CR2 |= 1;        // Turn on ADC1 by forcing bit 0 to 1 while keeping other bits unchanged
 159:Core/Src/main.c **** 
 160:Core/Src/main.c ****   /*** Turn on CRC Clock in AHB1ENR to enable CRC hardware ***/
 161:Core/Src/main.c **** 
 162:Core/Src/main.c **** 	RCC->AHB1ENR |= (1 << 12); // turn on crc clock
 163:Core/Src/main.c **** 
 164:Core/Src/main.c **** 
 165:Core/Src/main.c ****   /************************************************************************************************
 166:Core/Src/main.c ****   These commands are handled as part of the MX_TIM7_Init() function and don't need to be enabled
 167:Core/Src/main.c ****   RCC->AHB1ENR |= 1<<5; // Enable clock for timer 7
 168:Core/Src/main.c ****   __enable_irq(); // Enable interrupts
 169:Core/Src/main.c ****   NVIC_EnableIRQ(TIM7_IRQn); // Enable Timer 7 Interrupt in the NVIC controller
 170:Core/Src/main.c ****   *************************************************************************************************
 171:Core/Src/main.c **** 
 172:Core/Src/main.c ****   TIM7->PSC = 199; //250Khz timer clock prescaler value, 250Khz = 50Mhz / 200
 173:Core/Src/main.c ****   TIM7->ARR = 1; // Count to 1 then generate interrupt (divide by 2), 125Khz interrupt rate to incr
 174:Core/Src/main.c ****   TIM7->DIER |= 1; // Enable timer 7 interrupt
 175:Core/Src/main.c ****   TIM7->CR1 |= 1; // Enable timer counting
 176:Core/Src/main.c **** 
 177:Core/Src/main.c ****   /* USER CODE END 2 */
 178:Core/Src/main.c **** 
 179:Core/Src/main.c ****   /* Infinite loop */
 180:Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
 181:Core/Src/main.c **** 
 182:Core/Src/main.c **** 
 183:Core/Src/main.c **** 
 184:Core/Src/main.c **** 
 185:Core/Src/main.c **** 
 186:Core/Src/main.c ****   while (1)
 187:Core/Src/main.c ****   {
 188:Core/Src/main.c **** 	  int i,j;
 189:Core/Src/main.c **** 
 190:Core/Src/main.c **** 	  Message_Pointer = &Message[0];
 191:Core/Src/main.c **** 	  Save_Pointer = &Message[0];
 192:Core/Src/main.c **** 	  Message_Length = sizeof(Message)/sizeof(Message[0]);
 193:Core/Src/main.c **** 	  Delay_msec = 200;
 194:Core/Src/main.c **** 	  Animate_On = 1;
 195:Core/Src/main.c **** 
 196:Core/Src/main.c **** 		GPIOD->ODR = CRC_Rx ^ CRC_Tx;
 197:Core/Src/main.c **** 
 198:Core/Src/main.c **** 	  //********* Reset CRC value ********************
 199:Core/Src/main.c **** 		
 200:Core/Src/main.c **** 		CRC->CR |= 1; // reset crc to start value
 201:Core/Src/main.c **** 
 202:Core/Src/main.c **** 	  //********* Calculate CRC **********************
ARM GAS  /tmp/ccBd8lha.s 			page 5


 203:Core/Src/main.c **** 		
 204:Core/Src/main.c **** 		for (j = 0; j < Message_Length; j++) // loop through message
 205:Core/Src/main.c ****     {
 206:Core/Src/main.c **** 			CRC->DR = Message[j]; // send one byte to crc
 207:Core/Src/main.c ****     }
 208:Core/Src/main.c **** 
 209:Core/Src/main.c **** 	  //********* Read CRC value into CRC_Rx  ********
 210:Core/Src/main.c **** 		
 211:Core/Src/main.c **** 		CRC_Rx = CRC->DR; // get final crc value
 212:Core/Src/main.c **** 
 213:Core/Src/main.c **** 	  GPIOD->ODR = CRC_Rx ^ CRC_Tx;  //XOR the sent and received CRC values and display on LEDs
 214:Core/Src/main.c **** 
 215:Core/Src/main.c **** 	  HAL_Delay(5000);           // Delay 5 seconds to allow message to scroll
 216:Core/Src/main.c **** 
 217:Core/Src/main.c **** 	  Animate_On = 0;            // Stop scrolling message
 218:Core/Src/main.c **** 	  Seven_Segment(CRC_Tx);     // Display CRC for sent message
 219:Core/Src/main.c **** 	  HAL_Delay(1000);           // Delay 1 second
 220:Core/Src/main.c **** 	  for (i=0 ; i<8 ; i++)      // Clear the display
 221:Core/Src/main.c **** 	  	  {
 222:Core/Src/main.c **** 	  		  Seven_Segment_Digit(i,SPACE,0);
 223:Core/Src/main.c **** 	  	  }
 224:Core/Src/main.c **** 
 225:Core/Src/main.c **** 	  HAL_Delay(500);           // Delay 1/2 second
 226:Core/Src/main.c **** 	  Seven_Segment(CRC_Rx);    // Display CRC calculated from received message
 227:Core/Src/main.c **** 	  HAL_Delay(1000);          // Delay for 1 second
 228:Core/Src/main.c **** 
 229:Core/Src/main.c **** 
 230:Core/Src/main.c ****     /* USER CODE BEGIN 3 */
 231:Core/Src/main.c ****   }
 232:Core/Src/main.c ****   /* USER CODE END 3 */
 233:Core/Src/main.c **** }
